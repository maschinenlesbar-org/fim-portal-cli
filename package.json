{
  "name": "fim-portal-cli",
  "version": "1.0.0",
  "description": "TypeScript API client and CLI for the FIM Portal REST API (fimportal.de)",
  "type": "module",
  "bin": {
    "fim-portal": "dist/src/cli/index.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test \"dist/test/**/*.test.js\"",
    "docs": "typedoc src/index.ts --out out",
    "start": "node dist/src/cli/index.js"
  },
  "keywords": [
    "fim",
    "fimportal",
    "xdatenfelder",
    "xzufi",
    "xprozess",
    "cli",
    "api-client"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "typedoc": "^0.26.0"
  }
}
